{
  "name": "auditpilot",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source multi-agent SOC 2 readiness reference architecture",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "eval": "pnpm --filter @auditpilot/eval-harness eval",
    "eval:ci": "pnpm --filter @auditpilot/eval-harness eval:ci"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.0"
  },
  "devDependencies": {
    "promptfoo": "^0.117.0"
  }
}
