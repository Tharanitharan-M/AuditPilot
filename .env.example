# =============================================================================
# AuditPilot — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. .env.example is the only file committed.
#
# All required vars are marked [REQUIRED]. Optional vars show their default.
# Acceptance test (PLAN.md 0F.4):
#   python -c "from apps.api.config import Settings; Settings()"
# ... must raise a clear ValidationError when a REQUIRED var is missing.
# =============================================================================

# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=development          # development | staging | production  [REQUIRED]
LOG_LEVEL=info                   # debug | info | warning | error
GIT_SHA=local                    # set by CI — git rev-parse --short HEAD

# -----------------------------------------------------------------------------
# Database — Neon Postgres 16 + pgvector (ADR-0008)
# -----------------------------------------------------------------------------
# Format: postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
# Local Docker:  postgres://postgres:postgres@localhost:5432/auditpilot_dev
# Neon prod:     postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/auditpilot?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/auditpilot_dev  # [REQUIRED]

# Neon "direct" connection URL for Drizzle migrations (bypasses pooler)
# Same format as DATABASE_URL but points to the direct endpoint.
DIRECT_URL=postgres://postgres:postgres@localhost:5432/auditpilot_dev

# -----------------------------------------------------------------------------
# Redis — Upstash (ADR-0008)
# -----------------------------------------------------------------------------
# Local Docker:    redis://localhost:6379/0
# Upstash prod:    rediss://default:TOKEN@HOST:PORT
REDIS_URL=redis://localhost:6379/0  # [REQUIRED]

# Upstash REST token — used by the @upstash/redis HTTP client in Edge functions.
# Leave blank for local dev (the redis:// URL is used via ioredis instead).
REDIS_TOKEN=

# -----------------------------------------------------------------------------
# Supabase Auth (ADR-0008)
# -----------------------------------------------------------------------------
# Find these in Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co  # [REQUIRED]
SUPABASE_ANON_KEY=eyJ...                        # [REQUIRED] — safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...                # [REQUIRED] — NEVER expose to browser

# Used by FastAPI to verify Supabase JWTs without a round-trip to Supabase.
# Find in Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret             # [REQUIRED]

# -----------------------------------------------------------------------------
# Cloudflare R2 (ADR-0008)
# -----------------------------------------------------------------------------
# Find in Cloudflare Dashboard → R2 → Manage API Tokens
R2_ACCOUNT_ID=                   # [REQUIRED in staging/production]
R2_ACCESS_KEY_ID=                # [REQUIRED in staging/production]
R2_SECRET_ACCESS_KEY=            # [REQUIRED in staging/production]
R2_BUCKET_NAME=auditpilot-files  # [REQUIRED in staging/production]
# Public URL for pre-signed downloads (set to your R2 custom domain or .r2.dev URL)
R2_PUBLIC_URL=https://files.auditpilot.dev

# -----------------------------------------------------------------------------
# LLM — Google Gemini via LiteLLM (cost-aware-llm-pipeline skill)
# Default model: gemini/gemini-2.5-flash-lite  (fastest, cheapest)
# Long-context:  gemini/gemini-2.5-pro         (reserved for >32K context)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=                  # [REQUIRED for LLM calls]

# Fallback / alternative LLM provider (optional — LiteLLM routes automatically)
# ANTHROPIC_API_KEY=             # uncomment if using Claude as fallback
# OPENAI_API_KEY=                # uncomment if using GPT as fallback

# Per-session LLM cost cap in USD (AdversarialAuditor hard limit — ADR-0002)
LLM_BUDGET_CAP_USD=0.50

# -----------------------------------------------------------------------------
# Langfuse — LLM observability + prompt management (ADR-0009, ADR-0011)
# -----------------------------------------------------------------------------
# Find in Langfuse Dashboard → Project Settings → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...    # [REQUIRED for traces]
LANGFUSE_SECRET_KEY=sk-lf-...    # [REQUIRED for traces]
LANGFUSE_HOST=https://cloud.langfuse.com  # override for self-hosted

# -----------------------------------------------------------------------------
# Sentry — error monitoring (ADR-0009)
# -----------------------------------------------------------------------------
# FastAPI backend DSN — find in Sentry → Project → Settings → Client Keys
SENTRY_DSN=https://KEY@ORGID.ingest.sentry.io/PROJECTID

# -----------------------------------------------------------------------------
# Grafana Cloud — OTel metrics (ADR-0009)
# -----------------------------------------------------------------------------
# Find in Grafana Cloud → Stack → OpenTelemetry
OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
# Header format: "Authorization=Basic BASE64(INSTANCE_ID:TOKEN)"
OTLP_HEADERS=Authorization=Basic YOUR_BASE64_ENCODED_CREDENTIALS

# -----------------------------------------------------------------------------
# A2A — AdversarialAuditor service (ADR-0002, Sprint 8)
# -----------------------------------------------------------------------------
# URL of the AdversarialAuditor Cloud Run service
# Local Docker: http://localhost:8001
AUDITOR_URL=http://localhost:8001

# Ed25519 public key pinned in the orchestrator for AgentCard verification.
# Generated in Sprint 8: python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; k=Ed25519PrivateKey.generate(); print(k.public_key().public_bytes_raw().hex())"
AUDITOR_A2A_PUBLIC_KEY=

# Ed25519 private key for the auditor service to sign its AgentCard.
# KEEP SECRET — never commit. Store in Secret Manager in production.
A2A_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Cron endpoints — shared secret (Sprint 9, Sprint 11)
# -----------------------------------------------------------------------------
# Used to authenticate internal cron triggers from Vercel Cron / Cloud Scheduler.
# Generate: openssl rand -hex 32
CRON_SECRET=                     # [REQUIRED in staging/production]

# -----------------------------------------------------------------------------
# Demo account (ADR-0012, Sprint 11)
# -----------------------------------------------------------------------------
# UUID of the seeded demo user in Supabase Auth.
# Created in Sprint 11 via: apps/api/seeds/demo_seed.sql
DEMO_USER_ID=

# -----------------------------------------------------------------------------
# Frontend — Next.js 15 (apps/web)
# NEXT_PUBLIC_* vars are embedded in the browser bundle at build time.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co  # [REQUIRED]
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...                        # [REQUIRED]
NEXT_PUBLIC_API_URL=http://localhost:8000                   # [REQUIRED]

# Sentry browser DSN (safe to expose — scope-limited to error reporting only)
NEXT_PUBLIC_SENTRY_DSN=https://KEY@ORGID.ingest.sentry.io/PROJECTID

# PostHog — product analytics + session replay (ADR-0009)
# Find in PostHog → Project Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
